# Global daily report ceiling across all users (default 200). Adjust without redeploy.
GLOBAL_DAILY_REPORT_CEILING=200
# Auth0 Machine-to-Machine app credentials — required for verification email resend
# Create at: Auth0 Dashboard → Applications → Machine to Machine → Fides Management API
# Required scopes: read:users, update:users, create:user_tickets
AUTH0_M2M_DOMAIN=
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
